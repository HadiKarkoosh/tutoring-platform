# Port the Nest.js API listens on
PORT=4000

# Required in production — a long random string used to sign JWTs.
# In development, if this is left unset, a dev-only fallback is used automatically.
JWT_SECRET=change-me-to-a-long-random-string

# Path to the SQLite database file
DB_PATH=tutoring.sqlite

# Base URL of the frontend, used to build password-reset links
FRONTEND_URL=http://localhost:3000
